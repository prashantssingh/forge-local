# ForgeLocal Brain listens on loopback by default.
BRAIN_ADDRESS=127.0.0.1:8080

# Native Ollama and the single model used for every reasoning turn.
OLLAMA_URL=http://127.0.0.1:11434
BRAIN_MODEL=gpt-oss:20b
BRAIN_CONTEXT_SIZE=8192
BRAIN_REASONING=high

# Durable local memory and bounded sequential sub-agents.
BRAIN_DATA_DIR=./data
BRAIN_MEMORY_ITEMS=8
BRAIN_MAX_AGENTS=3

# Optional. Required automatically if BRAIN_ADDRESS is changed off loopback.
BRAIN_API_KEY=
