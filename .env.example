# Docker-to-host Ollama connection used by Open WebUI.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Local service ports.
WEBUI_PORT=3000
QDRANT_PORT=6333

# Local model choices.
PRIMARY_MODEL=qwen2.5-coder:14b
FALLBACK_MODEL=qwen2.5-coder:7b
EXPERIMENTAL_MODEL=qwen3-coder:30b

# Manual workflow safety limits.
AGENT_MAX_TASKS=3
AGENT_MAX_FILES_CHANGED=8
AGENT_REQUIRE_HUMAN_APPROVAL=true
